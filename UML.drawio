          </mxGeometry>
        </mxCell>
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\n\n&#39; ===== CLASSI ASTRATTE =====\nabstract class Personaggio {\n    #nome : String\n    #descrizione : String\n    #salute : int\n    +getNome() : String\n    +getDescrizione() : String\n    +getSalute() : int\n    +parla() : String\n    +attacca(bersaglio: Personaggio) : void\n    #subisciDanno(danno: int) : void\n}\n\nclass Protagonista {\n    -dannoArma : int\n    -forza : int\n    -carisma : int\n    -agilita : int\n    +getForza() : int\n    +modificaForza(int) : void\n    +getCarisma() : int\n    +modificaCarisma(int) : void\n    +getAgilita() : int\n    +modificaAgilita(int) : void\n    +setDannoArma(int) : void\n    +tentaAzione(String, int) : boolean\n    +parla() : String\n    +raccogli(Oggetto) : void\n    +attacca(Personaggio) : void\n    +stampaStato() : void\n}\n\nclass NPC {\n    +parla() : String\n    +assegnaMissione(Missione) : void\n    +getMissione() : Missione\n}\n\nclass Nemico {\n    -danno : int\n    +getDanno() : int\n    +parla() : String\n    +attacca(Personaggio) : void\n}\n\nclass Gigante {\n    +attaccoSpeciale(Personaggio) : void\n    +parla() : String\n}\n\n&#39; ===== INTERFACCE =====\ninterface Interagibile {\n    +interagisci(Protagonista) : boolean\n}\n\n&#39; ===== ECCEZIONI =====\nclass RPGException\n\n&#39; ===== OGGETTI E DATI =====\nclass Inventario {\n    +aggiungi(Oggetto) : void\n    +mostra() : void\n    +get(int) : Oggetto\n    +usa(int) : Oggetto\n}\n\nclass Oggetto {\n    -nome : String\n    -descrizione : String\n    -valore : int\n    -consumabile : boolean\n}\n\nclass Missione {\n    -descrizione : String\n    -completata : boolean\n    +avviaMissione() : void\n    +completaMissione() : void\n}\n\nclass Indizio {\n    -nome : String\n    -descrizione : String\n}\n\nclass Luogo {\n    -nome : String\n    -descrizione : String\n}\n\nclass Mappa {\n    -larghezza : int\n    -altezza : int\n}\n\n&#39; ===== LOGICA =====\nclass Movimento {\n    -x : int\n    -y : int\n}\n\nclass GestoreInput\nclass Direzione\nclass Leggi\nclass MotoreEpisodi\nclass Gioco\n\n&#39; ===== EREDITARIETA =====\nPersonaggio &lt;|-- Protagonista\nPersonaggio &lt;|-- NPC\nPersonaggio &lt;|-- Nemico\nNemico &lt;|-- Gigante\n\n&#39; ===== RELAZIONI =====\nProtagonista *-- Inventario\nInventario o-- Oggetto\nNPC o-- Missione\nMissione o-- Indizio\nMappa *-- Luogo\n\nMovimento --&gt; Mappa\nMovimento *-- GestoreInput\nGestoreInput --&gt; Direzione\nGestoreInput --&gt; Leggi\n\nGioco --&gt; Mappa\nGioco --&gt; Movimento\nGioco --&gt; Personaggio\nGioco --&gt; MotoreEpisodi\n\nMotoreEpisodi --&gt; Protagonista\nMotoreEpisodi --&gt; Nemico\nMotoreEpisodi --&gt; Missione\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="DegzwwD6ZxK4wKNYWNpg-3">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
