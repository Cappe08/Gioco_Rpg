        <mxCell id="DegzwwD6ZxK4wKNYWNpg-2" edge="1" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="192" y="171" as="sourcePoint" />
