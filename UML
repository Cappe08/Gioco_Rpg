classDiagram
    %% EREDITARIETA' E CLASSI ASTRATTE
    class Personaggio {
        <<abstract>>
        #nome : String
        #descrizione : String
        #salute : int
        +Personaggio(nome: String, descrizione: String, salute: int)
        +getNome() String
        +getDescrizione() String
        +getSalute() int
        +parla()* String
        +attacca(bersaglio: Personaggio) void
        #subisciDanno(danno: int) void
    }

    class Protagonista {
        -dannoArma : int
        -forza : int
        -carisma : int
        -agilita : int
        +Protagonista(nome: String, descrizione: String)
        +getForza() int
        +modificaForza(variazione: int) void
        +getCarisma() int
        +modificaCarisma(variazione: int) void
        +getAgilita() int
        +modificaAgilita(variazione: int) void
        +setDannoArma(nuovoDanno: int) void
        +tentaAzione(stat: String, difficolta: int) boolean
        +parla() String
        +raccogli(oggetto: Oggetto) void
        +attacca(bersaglio: Personaggio) void
        +stampaStato() void
    }

    class NPC {
        +NPC(nome: String, descrizione: String)
        +parla() String
        +assegnaMissione(m: Missione) void
        +getMissione() Missione
    }

    class Nemico {
        -danno : int
        +Nemico(nome: String, descrizione: String, salute: int, danno: int)
        +getDanno() int
        +parla() String
        +attacca(bersaglio: Personaggio) void
    }

    class Gigante {
        +Gigante()
        +attaccoSpeciale(giocatore: Personaggio) void
        +parla() String
    }

    Personaggio <|-- Protagonista
    Personaggio <|-- NPC
    Personaggio <|-- Nemico
    Nemico <|-- Gigante

    %% INTERFACCE ED ECCEZIONI
    class Interagibile {
        <<interface>>
        +interagisci(tony: Protagonista)* boolean
    }

    class RPGException {
        +RPGException(messaggio: String)
    }

    %% CLASSI CORE E STRUTTURE DATI
    class Inventario {
        -$CAPACITA_MAX : int
        +Inventario()
        +aggiungi(o: Oggetto) void
        +mostra() void
        +get(indice: int) Oggetto
        +usa(indice: int) Oggetto
        +toString() String
    }

    class Oggetto {
        -nome : String
        -descrizione : String
        -valore : int
        -consumabile : boolean
        +Oggetto(nome: String, descrizione: String, valore: int, consumabile: boolean)
        +isConsumabile() boolean
        +getNome() String
        +getDescrizione() String
        +getValore() int
        +toString() String
    }

    class Missione {
        -descrizione : String
        -completata : boolean
        +Missione(descrizione: String, ricompensa: Indizio)
        +getDescrizione() String
        +isCompletata() boolean
        +avviaMissione() void
        +completaMissione() void
        +daiRicompensa() Indizio
    }

    class Indizio {
        -nome : String
        -descrizione : String
        +Indizio(nome: String, descrizione: String)
        +getNome() String
        +getDescrizione() String
        +esamina() String
        +toString() String
    }

    class Luogo {
        -nome : String
        -descrizione : String
        +Luogo(nome: String, descrizione: String)
        +getNome() String
        +getDescrizione() String
        +toString() String
    }

    class Mappa {
        -larghezza : int
        -altezza : int
        +Mappa(larghezza: int, altezza: int)
        +posizionaLuogo(x: int, y: int, luogo: Luogo) void
        +getLuogo(x: int, y: int) Luogo
        +coordinateValide(x: int, y: int) boolean
        +isAttraversabile(x: int, y: int) boolean
        +getLarghezza() int
        +getAltezza() int
    }

    %% GESTIONE LOGICA E INPUT
    class Movimento {
        -x : int
        -y : int
        +Movimento(mappa: Mappa, xIniziale: int, yIniziale: int)
        +getX() int
        +getY() int
        +getLuogoCorrente() Luogo
        +muovi() void
        +muovi(direzione: Direzione) void
    }

    class GestoreInput {
        +GestoreInput()
        +leggiDirezione() Direzione
        +leggiDirezioneConRetry() Direzione
    }

    class Direzione {
        <<enumeration>>
        NORD
        SUD
        EST
        OVEST
    }

    class Leggi {
        -$br : BufferedReader
        -$s : String
        +$unBoolean() boolean
        +$unInt() int
        +$unoString() String
        +$unChar() char
        -$input() String
    }

    class MotoreEpisodi {
        -$episodioLocandaFatto : boolean
        -$episodioBarFatto : boolean
        -$episodioPiazzaFatto : boolean
        -$episodioTorriFatto : boolean
        +$attendi(millisecondi: int) void
        +$gestisciInterazione(luogo: String, tony: Protagonista, nemico: Nemico, nemici: Map) void
        +$episodioLocanda(tony: Protagonista) boolean
        +$episodioPiazza(tony: Protagonista) boolean
        +$episodioTorri(tony: Protagonista) boolean
        +$preCombattimentoPorta(tony: Protagonista, guardia: Nemico) void
        +$combattiBossFinale(tony: Protagonista, boss: Nemico, m: Missione, nemici: Map, luogo: String) void
        +$usaPozioneInCombattimento(tony: Protagonista) void
    }

    class Gioco {
        +$main(args: String[]) void
        -$inizializzaMappa() Mappa
        -$inizializzaNemici() Map
        -$combatti(tony: Protagonista, nemico: Nemico, nemici: Map, luogo: String) void
        -$gameLoop(tony: Protagonista, movimento: Movimento, nemici: Map, missione: Missione) void
    }

    %% RELAZIONI E ASSOCIAZIONI
    Protagonista *-- Inventario : possiede
    Inventario o-- Oggetto : contiene
    NPC o-- Missione : assegna
    Missione o-- Indizio : fornisce
    Mappa *-- Luogo : è formata da

    Movimento --> Mappa : naviga
    Movimento *-- GestoreInput : utilizza
    GestoreInput ..> Direzione : restituisce
    GestoreInput ..> Leggi : chiama

    Gioco ..> Mappa : inizializza
    Gioco ..> Movimento : gestisce
    Gioco ..> Personaggio : orchestra
    Gioco ..> MotoreEpisodi : invoca

    MotoreEpisodi ..> Protagonista : modifica
    MotoreEpisodi ..> Nemico : scontra
    MotoreEpisodi ..> Missione : completa